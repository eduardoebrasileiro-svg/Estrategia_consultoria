{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role and administrative link information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "cpf": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "adminId": { "type": "string", "description": "UID of the linked admin" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "cpf"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "amount", "category", "description", "date"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A financial goal set by the admin",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["pending", "achieved", "failed"] }
      },
      "required": ["title", "targetAmount"]
    },
    "Instruction": {
      "title": "Instruction",
      "description": "Message from the admin",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Profiles of the application users"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction records for a specific user"
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "Goals set by an admin for this user"
    },
    "/users/{userId}/instructions/{instructionId}": {
      "schema": "Instruction",
      "description": "Instructions sent by an admin"
    },
    "/linkRequests/{requestId}": {
      "schema": "object",
      "description": "Pending linking requests between admins and users"
    },
    "/admins/{userId}": {
      "schema": "object",
      "description": "User IDs that have administrative privileges"
    }
  }
}
