rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3 Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User Profile Validation
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 100
          && data.role in ['user', 'admin']
          && data.cpf is string && data.cpf.size() == 11
          && data.keys().hasAll(['email', 'role', 'createdAt', 'cpf'])
          && (data.keys().size() >= 4 && data.keys().size() <= 6);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Admin can list users to find via CPF (with careful querying)
      allow create: if isOwner(userId) 
                    && isValidUser(incoming())
                    && incoming().role == 'user'
                    && incoming().createdAt == request.time;
      allow update: if (isOwner(userId) && incoming().role == existing().role && incoming().createdAt == existing().createdAt)
                    || (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['adminId'])); // Linking
    }

    // Transactions Validation
    match /users/{userId}/transactions/{transactionId} {
      allow list, get: if isOwner(userId) || (isAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.adminId == request.auth.uid);
      allow create: if isOwner(userId) && isValidId(transactionId) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(userId);
    }

    // Goals & Instructions
    match /users/{userId}/goals/{goalId} {
      allow read: if isOwner(userId) || (isAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.adminId == request.auth.uid);
      allow write: if isAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.adminId == request.auth.uid;
    }

    match /users/{userId}/instructions/{instructionId} {
      allow read: if isOwner(userId) || (isAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.adminId == request.auth.uid);
      allow write: if isAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.adminId == request.auth.uid;
    }

    match /linkRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isSignedIn() && (incoming().userId == request.auth.uid || incoming().adminId == request.auth.uid);
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
