rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3 Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User Profile Validation
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 100
          && data.role in ['user', 'admin']
          && data.keys().hasAll(['email', 'role', 'createdAt'])
          && (data.keys().size() == 4 || data.keys().size() == 3);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) 
                    && isValidUser(incoming())
                    && incoming().role == 'user' // Users can't make themselves admins
                    && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
                    && isValidUser(incoming())
                    && incoming().role == existing().role // Protect role from self-edit
                    && incoming().createdAt == existing().createdAt;
    }

    // Transactions Validation
    function isValidTransaction(data) {
      return data.type in ['income', 'expense']
          && data.amount is number && data.amount > 0
          && data.category is string && data.category.size() <= 50
          && data.description is string && data.description.size() <= 200
          && data.date is string && data.date.size() <= 20
          && data.createdAt is timestamp;
    }

    match /users/{userId}/transactions/{transactionId} {
      allow list: if isOwner(userId) || isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) 
                    && isValidId(transactionId)
                    && isValidTransaction(incoming())
                    && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
                    && isValidTransaction(incoming())
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console or Admin SDK
    }
  }
}
